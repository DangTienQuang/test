using System;
using System.Linq;
using System.Threading.Tasks;
using AutoWashPro.DAL.Data;
using Microsoft.EntityFrameworkCore;
using DAL.Entities;

namespace AutoWashPro.BLL.Services
{
    public class DatabaseSeedingService : IDatabaseSeedingService
    {
        private readonly AutoWashDbContext _context;

        public DatabaseSeedingService(AutoWashDbContext context)
        {
            _context = context;
        }

        public async Task InitializeAndSeedAsync()
        {
            await _context.Database.MigrateAsync();

            var now = DateTime.UtcNow;

            var firstTier = await _context.Tiers.FirstOrDefaultAsync(t => t.MinAccumulatedPoints == 0);
            if (firstTier == null)
            {
                firstTier = new AutoWashPro.DAL.Entities.Tier
                {
                    TierName = "Standard",
                    PointMultiplier = 1.0,
                    BookingWindowDays = 7,
                    MinAccumulatedPoints = 0
                };
                _context.Tiers.Add(firstTier);
                await _context.SaveChangesAsync();
            }

            var vehicleType = await _context.VehicleTypes.FirstOrDefaultAsync();
            if (vehicleType == null)
            {
                vehicleType = new AutoWashPro.DAL.Entities.VehicleType
                {
                    Name = "Sedan",
                    BaseWeight = 1,
                    Description = "Xe 4 chỗ"
                };
                _context.VehicleTypes.Add(vehicleType);
                await _context.SaveChangesAsync();
            }

            var branchesInfo = new[]
            {
                new { Name = "Chi nhánh Trung Tâm", Address = "123 Lê Lợi, Quận 1, TP.HCM", ManagerPhone = "0888888888", Staff1Phone = "0777777777", Staff2Phone = "0777777778", ManagerName = "Nguyễn Văn A", Staff1Name = "Trần Văn B", Staff2Name = "Lê Văn C" },
                new { Name = "Chi nhánh Quận 1", Address = "456 Nguyễn Huệ, Quận 1, TP.HCM", ManagerPhone = "0888888881", Staff1Phone = "0777777711", Staff2Phone = "0777777712", ManagerName = "Phạm Thị D", Staff1Name = "Vũ Văn E", Staff2Name = "Hoàng Thị F" },
                new { Name = "Chi nhánh Quận 7", Address = "789 Nguyễn Văn Linh, Quận 7, TP.HCM", ManagerPhone = "0888888882", Staff1Phone = "0777777721", Staff2Phone = "0777777722", ManagerName = "Đặng Văn G", Staff1Name = "Bùi Thị H", Staff2Name = "Đỗ Văn I" }
            };

            foreach (var bInfo in branchesInfo)
            {
                var branch = await _context.Branches.FirstOrDefaultAsync(b => b.Name == bInfo.Name);
                if (branch == null)
                {
                    branch = new AutoWashPro.DAL.Entities.Branch
                    {
                        Name = bInfo.Name,
                        Address = bInfo.Address,
                        IsActive = true
                    };
                    _context.Branches.Add(branch);
                    await _context.SaveChangesAsync();

                    _context.Lanes.Add(new AutoWashPro.DAL.Entities.Lane { BranchId = branch.BranchId, Name = "Lane 1 - Normal", IsActive = true });
                    _context.Lanes.Add(new AutoWashPro.DAL.Entities.Lane { BranchId = branch.BranchId, Name = "Lane 2 - VIP", IsActive = true });
                    await _context.SaveChangesAsync();

                    for (int hour = 8; hour < 17; hour++)
                    {
                        _context.TimeSlots.Add(new AutoWashPro.DAL.Entities.TimeSlot
                        {
                            BranchId = branch.BranchId,
                            StartTime = new TimeSpan(hour, 0, 0),
                            EndTime = new TimeSpan(hour + 1, 0, 0),
                            MaxCapacity = 3,
                            IsVipOnly = false
                        });
                    }
                    await _context.SaveChangesAsync();
                }

                var manager = await _context.Users.FirstOrDefaultAsync(u => u.PhoneNumber == bInfo.ManagerPhone);
                if (manager == null)
                {
                    manager = new AutoWashPro.DAL.Entities.User { PhoneNumber = bInfo.ManagerPhone, PasswordHash = BCrypt.Net.BCrypt.HashPassword("123456aA@"), Role = "Manager", Status = "Active" };
                    _context.Users.Add(manager);
                    await _context.SaveChangesAsync();
                    _context.EmployeeProfiles.Add(new AutoWashPro.DAL.Entities.EmployeeProfile { EmployeeId = manager.UserId, BranchId = branch.BranchId, FullName = $"Quản lý {bInfo.ManagerName}" });
                    await _context.SaveChangesAsync();
                }

                var staff1 = await _context.Users.FirstOrDefaultAsync(u => u.PhoneNumber == bInfo.Staff1Phone);
                if (staff1 == null)
                {
                    staff1 = new AutoWashPro.DAL.Entities.User { PhoneNumber = bInfo.Staff1Phone, PasswordHash = BCrypt.Net.BCrypt.HashPassword("123456aA@"), Role = "Staff", Status = "Active" };
                    _context.Users.Add(staff1);
                    await _context.SaveChangesAsync();
                    _context.EmployeeProfiles.Add(new AutoWashPro.DAL.Entities.EmployeeProfile { EmployeeId = staff1.UserId, BranchId = branch.BranchId, FullName = $"Nhân viên {bInfo.Staff1Name}" });
                    await _context.SaveChangesAsync();
                }

                var staff2 = await _context.Users.FirstOrDefaultAsync(u => u.PhoneNumber == bInfo.Staff2Phone);
                if (staff2 == null)
                {
                    staff2 = new AutoWashPro.DAL.Entities.User { PhoneNumber = bInfo.Staff2Phone, PasswordHash = BCrypt.Net.BCrypt.HashPassword("123456aA@"), Role = "Staff", Status = "Active" };
                    _context.Users.Add(staff2);
                    await _context.SaveChangesAsync();
                    _context.EmployeeProfiles.Add(new AutoWashPro.DAL.Entities.EmployeeProfile { EmployeeId = staff2.UserId, BranchId = branch.BranchId, FullName = $"Nhân viên {bInfo.Staff2Name}" });
                    await _context.SaveChangesAsync();
                }
            }

            if (!await _context.Users.AnyAsync(u => u.Role == "Admin"))
            {
                var admin = new AutoWashPro.DAL.Entities.User { PhoneNumber = "0999999999", PasswordHash = BCrypt.Net.BCrypt.HashPassword("Admin@123"), Role = "Admin", Status = "Active" };
                _context.Users.Add(admin);
                await _context.SaveChangesAsync();
                _context.CustomerProfiles.Add(new AutoWashPro.DAL.Entities.CustomerProfile { UserId = admin.UserId, FullName = "System Admin", TierId = firstTier.TierId, ChurnScore = 0, TotalPoint = 0, PromotionPoint = 0 });
                await _context.SaveChangesAsync();
            }

            var businessAccountsInfo = new[]
            {
                new { CompanyName = "Công ty Vận Tải A", Phone = "0666666661", DelegateName = "Đại diện Cty A" },
                new { CompanyName = "Hãng Taxi B", Phone = "0666666662", DelegateName = "Đại diện Cty B" }
            };

            foreach (var bAcc in businessAccountsInfo)
            {
                var businessUser = await _context.Users.FirstOrDefaultAsync(u => u.PhoneNumber == bAcc.Phone);
                if (businessUser == null)
                {
                    businessUser = new AutoWashPro.DAL.Entities.User { PhoneNumber = bAcc.Phone, PasswordHash = BCrypt.Net.BCrypt.HashPassword("123456aA@"), Role = "Customer", Status = "Active" };
                    _context.Users.Add(businessUser);
                    await _context.SaveChangesAsync();

                    _context.CustomerProfiles.Add(new AutoWashPro.DAL.Entities.CustomerProfile { UserId = businessUser.UserId, FullName = bAcc.DelegateName, TierId = firstTier.TierId });
                    await _context.SaveChangesAsync();

                    var businessProfile = new global::DAL.Entities.BusinessProfile
                    {
                        UserId = businessUser.UserId,
                        CompanyName = bAcc.CompanyName,
                        RepresentativeName = bAcc.DelegateName,
                        CreatedAt = DateTime.UtcNow,
                        ApprovalStatus = "Approved",
                        BusinessLicenseFileUrl = "dummy_url.pdf",
                        MonthlyCreditLimit = 10000000,
                        ContractStartDate = DateTime.UtcNow,
                        ContractEndDate = DateTime.UtcNow.AddYears(1),
                        IsContractActive = true
                    };
                    _context.BusinessProfiles.Add(businessProfile);
                    await _context.SaveChangesAsync();

                    var batch = new global::DAL.Entities.FleetImportBatch
                    {
                        BusinessProfileId = businessProfile.BusinessProfileId,
                        FileUrl = "dummy_batch.csv",
                        Status = "Completed",
                        TotalRows = 2,
                        SuccessRows = 2,
                        FailedRows = 0,
                        CreatedAt = DateTime.UtcNow
                    };
                    _context.FleetImportBatches.Add(batch);
                    await _context.SaveChangesAsync();

                    _context.FleetVehicles.Add(new global::DAL.Entities.FleetVehicle
                    {
                        BusinessProfileId = businessProfile.BusinessProfileId,
                        LicensePlate = $"51A-{new Random().Next(10000, 99999)}",
                        VehicleTypeId = vehicleType.Id,
                        Brand = "Toyota",
                        Model = "Vios",
                        Status = "Approved",
                        CreatedAt = DateTime.UtcNow,
                        FleetImportBatchId = batch.FleetImportBatchId
                    });
                    _context.FleetVehicles.Add(new global::DAL.Entities.FleetVehicle
                    {
                        BusinessProfileId = businessProfile.BusinessProfileId,
                        LicensePlate = $"51A-{new Random().Next(10000, 99999)}",
                        VehicleTypeId = vehicleType.Id,
                        Brand = "Honda",
                        Model = "City",
                        Status = "Approved",
                        CreatedAt = DateTime.UtcNow,
                        FleetImportBatchId = batch.FleetImportBatchId
                    });
                    await _context.SaveChangesAsync();
                }
            }

            if (!await _context.Users.AnyAsync(u => u.Role == "Customer" && u.PhoneNumber == "0666666666"))
            {
                var customer = new AutoWashPro.DAL.Entities.User
                {
                    PhoneNumber = "0666666666",
                    PasswordHash = BCrypt.Net.BCrypt.HashPassword("User@123"),
                    Role = "Customer",
                    Status = "Active"
                };
                _context.Users.Add(customer);
                await _context.SaveChangesAsync();

                _context.CustomerProfiles.Add(new AutoWashPro.DAL.Entities.CustomerProfile
                {
                    UserId = customer.UserId,
                    FullName = "Khách Hàng VIP",
                    TierId = firstTier.TierId,
                    ChurnScore = 0,
                    TotalPoint = 0,
                    PromotionPoint = 0
                });
                await _context.SaveChangesAsync();

                var wallet = new AutoWashPro.DAL.Entities.Wallet
                {
                    UserId = customer.UserId,
                    Balance = 1000000
                };
                _context.Wallets.Add(wallet);
                await _context.SaveChangesAsync();

                _context.Transactions.Add(new AutoWashPro.DAL.Entities.Transaction
                {
                    WalletId = wallet.WalletId,
                    Amount = 1000000,
                    TransactionType = "Topup",
                    Description = "Hệ thống tặng tiền trải nghiệm",
                    Status = "Completed"
                });
                await _context.SaveChangesAsync();
            }

            if (!await _context.Vouchers.AnyAsync())
            {
                var vouchers = new[]
                {
                    new AutoWashPro.DAL.Entities.Voucher
                    {
                        Code = "WELCOME10",
                        DiscountAmount = 10000,
                        MaxUsages = 1000,
                        MaxUsagePerUser = 1,
                        ExpiryDate = DateTime.UtcNow.AddMonths(1),
                        StartDate = DateTime.UtcNow,
                        IsActive = true,
                        PointsRequired = 0,
                        VoucherType = AutoWashPro.DAL.Enums.VoucherType.Discount,
                        CampaignType = AutoWashPro.DAL.Enums.VoucherCampaignType.Welcome,
                        MinOrderAmount = 50000,
                        RequiredTierId = firstTier.TierId
                    },
                    new AutoWashPro.DAL.Entities.Voucher
                    {
                        Code = "HAPPYHOUR",
                        DiscountAmount = 20000,
                        MaxUsages = 500,
                        MaxUsagePerUser = 2,
                        ExpiryDate = DateTime.UtcNow.AddMonths(2),
                        StartDate = DateTime.UtcNow,
                        IsActive = true,
                        PointsRequired = 50,
                        VoucherType = AutoWashPro.DAL.Enums.VoucherType.Discount,
                        CampaignType = AutoWashPro.DAL.Enums.VoucherCampaignType.Manual,
                        ValidStartTime = new TimeSpan(14, 0, 0), // 2 PM
                        ValidEndTime = new TimeSpan(16, 0, 0),   // 4 PM
                        MinOrderAmount = 100000,
                        RequiredTierId = firstTier.TierId
                    },
                    new AutoWashPro.DAL.Entities.Voucher
                    {
                        Code = "FREECOFFEE",
                        DiscountAmount = 0, // Physical gift doesn't have financial discount
                        MaxUsages = 100,
                        MaxUsagePerUser = 1,
                        ExpiryDate = DateTime.UtcNow.AddMonths(6),
                        StartDate = DateTime.UtcNow,
                        IsActive = true,
                        PointsRequired = 200,
                        VoucherType = AutoWashPro.DAL.Enums.VoucherType.PhysicalGift,
                        CampaignType = AutoWashPro.DAL.Enums.VoucherCampaignType.Manual,
                        RequiredTierId = firstTier.TierId
                    }
                };
                _context.Vouchers.AddRange(vouchers);
                await _context.SaveChangesAsync();
            }
        }

    }
}
